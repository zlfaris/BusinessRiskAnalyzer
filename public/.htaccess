<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Aturan untuk Tampilan (index.html)
    # Jika root folder dibuka, tampilkan index.html
    RewriteRule ^$ index.html [L]

    # 2. Aturan untuk File Statis
    # Jika file atau folder fisik yang diminta ada (seperti gambar/CSS), langsung tampilkan saja
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 3. Aturan untuk API (index.php)
    # Jika bukan index.html dan bukan file fisik, alihkan permintaan ke index.php
    # Aturan ini menangani API seperti /api/login dan /api/register
    RewriteCond %{REQUEST_FILENAME} !index.html
    RewriteRule . index.php [L]
</IfModule>